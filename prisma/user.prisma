model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          Role      @default(USER)
  active        Boolean   @default(true)
  deactivatedAt DateTime?

  refreshTokens      RefreshToken[]
  verificationTokens VerificationToken[]

  ownedWorkspaces  Workspace[]       @relation("WorkspaceOwner")
  workspaceMembers WorkspaceMember[]

  ledProjects     Project[]       @relation("ProjectLead")
  defaultProjects Project[]       @relation("ProjectDefaultAssignee")
  projectMembers  ProjectMember[]

  reportedIssues Issue[] @relation("IssueReporter")
  assignedIssues Issue[] @relation("IssueAssignee")

  comments    Comment[]    @relation("CommentAuthor")
  attachments Attachment[] @relation("AttachmentUploader")
  worklogs    Worklog[]    @relation("WorklogUser")
  activities  Activity[]   @relation("ActivityUser")
  starredIssues IssueStar[] @relation("IssueStarUser")
  watchedIssues IssueWatcher[] @relation("IssueWatcherUser")
  notifications Notification[] @relation("NotificationRecipient")
  savedFilters  SavedFilter[]  @relation("SavedFilterOwner")
  issueShareTokens IssueShareToken[] @relation("IssueShareTokenCreator")
  workspaceInvites WorkspaceInviteLink[] @relation("WorkspaceInviteCreator")
  notificationPreferences NotificationPreference[] @relation("NotificationPreferenceUser")
  throttleOverrides       ThrottleOverride[]       @relation("ThrottleOverrideAuthor")
  personalAccessTokens    PersonalAccessToken[]    @relation("PatOwner")
  createdWebhooks         Webhook[]                @relation("WebhookCreator")

  createdFeatureFlags FeatureFlag[]   @relation("FeatureFlagCreator")
  adminAuditLogs      AdminAuditLog[] @relation("AdminAudit")

  // GDPR — user-initiated soft deletion. The nightly cron hard-deletes
  // accounts whose request is older than 30 days. Until that grace window
  // closes, the user can cancel the request from the profile page.
  deletionRequestedAt DateTime?

  // Admin analytics queries signups over a date range.
  @@index([createdAt])
  @@index([deletionRequestedAt])
}
