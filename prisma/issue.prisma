model Issue {
  id            String        @id @default(uuid())
  key           String        @unique
  projectId     String
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type          IssueType     @default(TASK)
  summary       String
  description   String?
  priority      IssuePriority @default(MEDIUM)
  reporterId    String
  reporter      User          @relation("IssueReporter", fields: [reporterId], references: [id])
  assigneeId    String?
  assignee      User?         @relation("IssueAssignee", fields: [assigneeId], references: [id])
  parentId      String?
  parent        Issue?        @relation("IssueSubtasks", fields: [parentId], references: [id])
  children      Issue[]       @relation("IssueSubtasks")
  epicId        String?
  epic          Issue?        @relation("EpicIssues", fields: [epicId], references: [id])
  epicChildren  Issue[]       @relation("EpicIssues")
  sprintId      String?
  sprint        Sprint?       @relation(fields: [sprintId], references: [id])
  boardColumnId String?
  boardColumn   BoardColumn?  @relation(fields: [boardColumnId], references: [id])
  position      Int           @default(0)
  storyPoints   Int?
  // Phase 2.3 — time tracking. Both stored as seconds; UI parses "2h 30m"
  // into total seconds. Nullable so existing rows stay valid.
  originalEstimate  Int?
  remainingEstimate Int?
  dueDate       DateTime?
  startDate     DateTime?
  completedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  labels        IssueLabel[]
  comments      Comment[]
  attachments   Attachment[]
  worklogs      Worklog[]
  activities    Activity[]
  stars         IssueStar[]
  watchers      IssueWatcher[]
  outboundLinks IssueLink[]   @relation("IssueLinkSource")
  inboundLinks  IssueLink[]   @relation("IssueLinkTarget")

  @@index([projectId])
  @@index([assigneeId])
  @@index([sprintId])
  @@index([boardColumnId])
  @@index([epicId])
}

model IssueStar {
  issueId   String
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("IssueStarUser", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([issueId, userId])
  @@index([userId, createdAt])
}

model IssueWatcher {
  issueId   String
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("IssueWatcherUser", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([issueId, userId])
  @@index([userId])
}

model IssueLink {
  id            String        @id @default(uuid())
  sourceIssueId String
  source        Issue         @relation("IssueLinkSource", fields: [sourceIssueId], references: [id], onDelete: Cascade)
  targetIssueId String
  target        Issue         @relation("IssueLinkTarget", fields: [targetIssueId], references: [id], onDelete: Cascade)
  type          IssueLinkType
  createdAt     DateTime      @default(now())

  // No two identical links between the same pair + type (idempotent UI).
  @@unique([sourceIssueId, targetIssueId, type])
  @@index([sourceIssueId])
  @@index([targetIssueId])
}

model Label {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  color     String   @default("#6b778c")
  createdAt DateTime @default(now())

  issues IssueLabel[]

  @@unique([projectId, name])
  @@index([projectId])
}

model IssueLabel {
  issueId String
  issue   Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  labelId String
  label   Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([issueId, labelId])
}
