model Workspace {
  id          String   @id @default(uuid())
  name        String
  // Slug is NOT used in URLs — routes use `workspaceId` (UUID). It only
  // surfaces in admin search and a few display strings. So uniqueness is
  // scoped per-owner: two unrelated users can each have a "marketing"
  // workspace without colliding. The same owner creating "Marketing" twice
  // still gets auto-suffixed ("marketing", "marketing-2") by the service.
  slug        String
  description String?
  logoUrl     String?
  ownerId     String
  owner       User     @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     WorkspaceMember[]
  projects    Project[]
  inviteLinks WorkspaceInviteLink[]
  webhooks    Webhook[]             @relation("WebhookWorkspace")

  @@unique([ownerId, slug])
  @@index([ownerId])
}

model WorkspaceMember {
  id          String        @id @default(uuid())
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        WorkspaceRole @default(MEMBER)
  joinedAt    DateTime      @default(now())

  @@unique([workspaceId, userId])
  @@index([userId])
}
