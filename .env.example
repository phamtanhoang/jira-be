# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED — server fails / behaves badly without these
# ─────────────────────────────────────────────────────────────────────────────
# Postgres connection string. Use Neon, Supabase Postgres, or local Docker.
# Format: postgresql://USER:PASS@HOST/DB?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

PORT=3031

# OTP / verification token TTL (seconds). 5 minutes default.
TOKEN_VERIFY_EXPIRY=300

# JWT signing secret — MUST be unguessable in production (32+ random bytes).
# Generate: `openssl rand -base64 48`
JWT_SECRET=change-me-in-production
JWT_ACCESS_TOKEN_EXPIRATION=300
JWT_REFRESH_TOKEN_EXPIRATION=604800

# RequestLog retention (seconds). 30 days default.
LOG_RETENTION_EXPIRY=2592000

# Comma-separated origins allowed by CORS.
CORS_ORIGIN=http://localhost:3030
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED — email (Resend)
# ─────────────────────────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED — file storage (Supabase)
# ─────────────────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — Sentry (production-only)
# ─────────────────────────────────────────────────────────────────────────────
# When DSN is empty OR NODE_ENV !== 'production', SentryService no-ops.
SENTRY_DSN=
SENTRY_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — Mail "from" header
# ─────────────────────────────────────────────────────────────────────────────
# Fallback used by MailService when admin hasn't filled `app.email` setting in
# DB. Resend rejects sends with empty `from`. Format: bare email or
# "Display Name <addr@domain>".
MAIL_FROM=no-reply@example.com
MAIL_FROM_NAME=Jira Clone

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — OAuth (Google, GitHub)
# Empty/missing → strategy stays dormant, OAuth button hidden on sign-in.
# ─────────────────────────────────────────────────────────────────────────────
# Register at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3031/auth/google/callback

# Register at: https://github.com/settings/developers → New OAuth App
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3031/auth/github/callback

# Where BE redirects after successful OAuth callback. Falls back to first
# CORS_ORIGIN when empty.
FRONTEND_URL=http://localhost:3030

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — Web Push (VAPID)
# Browser push notifications. Generate keys: `npx web-push generate-vapid-keys`
# Empty → push module dormant, FE hides toggle.
# ─────────────────────────────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@example.com

# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — Cache (Redis)
# Empty REDIS_URL → in-memory cache (single-process, fine for single VPS).
# Switch to Redis URL once running multi-instance / serverless.
# Example providers: redis://localhost:6379 (Docker),
# rediss://default:<password>@<host>.upstash.io:6379 (Upstash free tier)
# ─────────────────────────────────────────────────────────────────────────────
REDIS_URL=
CACHE_TTL_DEFAULT=60
# Set to "1" to bypass cache reads/writes (kill switch for diagnosis).
CACHE_DISABLED=0
